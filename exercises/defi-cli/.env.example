# Optional — defaults work out of the box.
# Override only if you need custom endpoints.

# Pyth Hermes endpoint (returns parsed JSON price updates)
# Default: https://hermes.pyth.network
# PYTH_HERMES_URL=https://hermes.pyth.network

# Jupiter Quote API endpoint (mainnet liquidity)
# Default: https://lite-api.jup.ag
# JUPITER_API_URL=https://lite-api.jup.ag

# Solana devnet RPC (optional — used for on-chain Pyth account verification)
# Default: https://api.devnet.solana.com
# SOLANA_DEVNET_RPC=https://api.devnet.solana.com
