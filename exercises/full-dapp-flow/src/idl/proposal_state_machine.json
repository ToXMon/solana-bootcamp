  "types": [
    {
      "name": "Proposal",
      "docs": [
        "Proposal account: stores all proposal data.",
        "Space: 8 (discriminator) + 32 (creator) + 8 (proposal_id) + 4+64 (title) + 1 (state) + 8 (yes_votes) + 8 (no_votes) + 1 (bump) = 134"
      ],
